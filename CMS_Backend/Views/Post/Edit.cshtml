@model CMS.Data.Entities.Post

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Sửa bài viết";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">
                <i class="bi bi-pencil-square"></i> SỬA BÀI VIẾT
            </h4>
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">

                <!-- Giữ lại ID -->
                <input asp-for="Id" type="hidden" />

                <!-- Giữ lại ảnh cũ nếu không đổi -->
                <input asp-for="ImageUrl" type="hidden" />

                <div class="row">
                    <div class="col-md-8">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề bài viết:</label>
                            <input asp-for="Title"
                                   class="form-control"
                                   placeholder="Nhập tiêu đề..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nội dung:</label>
                            <textarea asp-for="Content"
                                      class="form-control"
                                      rows="10"></textarea>
                        </div>

                    </div>

                    <div class="col-md-4">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Danh mục:</label>
                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.CategoryList"
                                    class="form-select">
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ảnh hiện tại:</label><br />

                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl"
                                     class="img-thumbnail"
                                     style="width:100%; max-height:250px; object-fit:cover;" />
                            }
                            else
                            {
                                <p class="text-muted">Chưa có ảnh</p>
                            }
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Chọn ảnh mới:</label>
                            <input type="file"
                                   name="uploadImage"
                                   class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngày đăng:</label>
                            <input asp-for="CreatedDate"
                                   type="date"
                                   class="form-control" />
                        </div>

                        <hr />

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning">
                                <i class="bi bi-save"></i> Cập nhật bài viết
                            </button>

                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại
                            </a>
                        </div>

                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>

    <script>
        ClassicEditor
            .create(document.querySelector('#Content'))
            .catch(error => {
                console.error(error);
            });
    </script>
}