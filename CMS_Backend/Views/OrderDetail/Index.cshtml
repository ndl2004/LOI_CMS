@model IEnumerable<CMS.Data.Entities.OrderDetail>

<div class="container mt-4">
    <h2>CHI TIẾT ĐƠN HÀNG</h2>

    <table class="table table-bordered">
        <tr>
            <th>ID</th>
            <th>Order ID</th>
            <th>Product ID</th>
            <th>Số lượng</th>
            <th>Đơn giá</th>
        </tr>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.OrderId</td>
                <td>@item.ProductId</td>
                <td>@item.Quantity</td>
                <td>@item.UnitPrice.ToString("N0") VNĐ</td>
            </tr>
        }
    </table>
</div>