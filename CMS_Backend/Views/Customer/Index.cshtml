@model IEnumerable<CMS.Data.Entities.Customer>

<div class="container mt-4">
    <h2 class="text-success mb-4">DANH SÁCH KHÁCH HÀNG</h2>

    <table class="table table-bordered table-hover shadow-sm">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Họ tên</th>
                <th>Email</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FullName</td>
                    <td>@item.Email</td>
                </tr>
            }
        </tbody>
    </table>
</div>