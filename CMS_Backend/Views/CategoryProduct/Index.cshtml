@model IEnumerable<CMS.Data.Entities.CategoryProduct>

<h2>Danh sách CategoriesProducts</h2>

<table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Tên danh mục sản phẩm</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.Id</td>
            <td>@item.Name</td>
        </tr>
    }
</table>